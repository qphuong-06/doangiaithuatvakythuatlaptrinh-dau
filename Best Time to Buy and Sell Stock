class Solution(object):
    def maxProfit(self, prices):
        """
        :type prices: List[int]
        :rtype: int
        """
        n = len(prices)
        maxi = 0
        profit = 0 
        i,j = 0,1
        while i<n and j < n:
            if prices[j] > prices[i]:
                profit = prices[j] - prices[i]
                maxi = max(profit, maxi)
            else:
                i = j
            j += 1
        return maxi
            