class Solution(object):
    def isPerfectSquare(self, num):
        """
        :type num: int
        :rtype: bool
        """
        beg, end = 1, num
        while beg <= end:
            mid = beg + (end - beg) // 2
            square = mid * mid
            if square == num:
                return True
            elif square > num:
                end = mid - 1
            else:
                beg = mid + 1
        return False
